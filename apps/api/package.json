{
  "name": "@skillup/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@sentry/node": "^10.27.0",
    "@skillup/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.5",
    "hono-pino": "^0.10.2",
    "pg": "^8.16.3",
    "pino": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
